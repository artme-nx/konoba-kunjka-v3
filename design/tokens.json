{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "stone": {
        "50": { "$value": "#FAF3E6", "$type": "color" },
        "100": { "$value": "#F2E6CC", "$type": "color" },
        "300": { "$value": "#E1CB9C", "$type": "color" },
        "500": { "$value": "#93805C", "$type": "color" }
      },
      "ink": {
        "950": { "$value": "#0A2226", "$type": "color" },
        "900": { "$value": "#0F2E32", "$type": "color" },
        "800": { "$value": "#1B454A", "$type": "color" },
        "700": { "$value": "#2C5C60", "$type": "color" }
      },
      "rust": {
        "500": { "$value": "#C2612E", "$type": "color" },
        "600": { "$value": "#A24C21", "$type": "color" },
        "900": { "$value": "#3E2211", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-newsreader), 'Newsreader', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-worksans), 'Work Sans', system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.26em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.stone.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "card": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "muted": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.stone.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.stone.50}", "$type": "color" },
    "border": { "$value": "{primitive.color.stone.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.rust.500}", "$type": "color" },
    "radius": { "$value": "0.7rem", "$type": "dimension" },
    "rust": { "$value": "{primitive.color.rust.500}", "$type": "color" },
    "rust-dim": { "$value": "{primitive.color.rust.900}", "$type": "color" },
    "ink": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.stone.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.7rem, 7.2vw, 6rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.04", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 50% 100%, rgba(194, 97, 46, 0.28), rgba(62, 34, 17, 0.12) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(10, 34, 38, 0.94) 0%, rgba(10, 34, 38, 0.32) 42%, rgba(10, 34, 38, 0.5) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.rust.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.stone.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.rust.600}", "$type": "color" },
      "ghost-border": { "$value": "rgba(250, 243, 230, 0.4)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.rust.500}", "$type": "color" }
    }
  }
}
